rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /events/{eventId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /attendees/{attendeeId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
                              && (request.auth.uid == attendeeId
                                  || request.auth.token.role == 'organizer');
      }

      match /sessions/{sessionId} {
        allow read: if request.auth != null;

        match /reactions/{reactionId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null
                        && request.resource.data.keys()
                           .hasOnly(['emoji', 'userId', 'timestamp'])
                        && request.resource.data.emoji is string
                        && request.resource.data.emoji.size() <= 4;
        }

        match /polls/{pollId} {
          allow read: if request.auth != null;

          match /votes/{voterId} {
            allow read: if request.auth != null;
            allow create, update: if request.auth != null
                                  && request.auth.uid == voterId;
          }
        }

        match /questions/{questionId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null
                        && request.resource.data.keys()
                           .hasOnly(['text', 'userId', 'userName', 'upvotes', 'timestamp'])
                        && request.resource.data.text is string
                        && request.resource.data.text.size() <= 500;
        }
      }

      match /photos/{photoId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }
  }
}

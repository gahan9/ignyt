rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // `role: 'organizer'` is a Firebase custom claim. It must be set server-side
    // via the Admin SDK — see backend/scripts/grant_organizer.py. A fresh
    // Google/email sign-in does NOT carry this claim by default.
    function isOrganizer() {
      return isSignedIn() && request.auth.token.role == 'organizer';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Demo escape hatch: the single hard-coded demo event is writable by any
    // signed-in user so `seedDemoData()` and the check-in flow work out of the
    // box without a custom-claim round-trip. Real events stay locked down to
    // organizers. The literal here must stay in sync with DEMO_EVENT_ID in
    // frontend/src/lib/constants.ts.
    function isDemoEvent(eventId) {
      return eventId == 'demo-event';
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isOrganizer() || (isSignedIn() && isDemoEvent(eventId));

      match /attendees/{attendeeId} {
        allow read: if isSignedIn();
        allow write: if isOwner(attendeeId)
                     || isOrganizer()
                     || (isSignedIn() && isDemoEvent(eventId));
      }

      match /sessions/{sessionId} {
        allow read: if isSignedIn();
        allow write: if isOrganizer() || (isSignedIn() && isDemoEvent(eventId));

        match /reactions/{reactionId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
        }

        match /questions/{questionId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOrganizer();
        }
      }

      match /photos/{photoId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isOrganizer();
      }
    }
  }
}

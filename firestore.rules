rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user logged in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Does the user have the organizer role?
    function isOrganizer() {
      return isSignedIn() && request.auth.token.role == 'organizer';
    }

    // Helper: Is this the user's own document?
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isOrganizer();

      match /attendees/{attendeeId} {
        allow read: if isSignedIn();
        allow write: if isOwner(attendeeId) || isOrganizer();
      }

      match /sessions/{sessionId} {
        allow read: if isSignedIn();
        allow write: if isOrganizer();

        match /reactions/{reactionId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
        }

        match /questions/{questionId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isOrganizer(); // For moderating questions
        }
      }

      match /photos/{photoId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isOrganizer();
      }
    }
  }
}

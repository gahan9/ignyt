# Copy to .env.local for local development.
# Every variable must be prefixed with VITE_ so Vite exposes it to the client bundle.
# The Firebase identifiers below are public project IDs -- not secrets -- but treat
# each project as a trust boundary and never commit the real values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend FastAPI base URL.
# - Dev: leave blank. The Vite dev server (see vite.config.ts) proxies /api to
#   http://localhost:8080, so requests are same-origin and Firebase ID tokens
#   don't trip CORS.
# - Prod: set to your Cloud Run URL, e.g. https://ignyt-api-xxxx.a.run.app
VITE_API_URL=

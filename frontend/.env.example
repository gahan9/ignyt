# Copy to .env.local (or .env) for local development.
# Every variable must be prefixed with VITE_ so Vite exposes it to the client bundle.
# These are public identifiers -- not secrets -- but treat the project as a
# boundary and never commit the real values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend API base URL (FastAPI on Cloud Run in prod).
# Leave blank for same-origin proxy via Firebase Hosting rewrites.
VITE_API_BASE_URL=http://localhost:8000
